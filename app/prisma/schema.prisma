generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Project - Top-level container for test plans
model Project {
  id          String      @id @default(uuid())
  name        String
  description String?     @db.Text
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  
  testPlans   TestPlan[]
  
  @@map("projects")
}

// Test Plan - Groups related test cases together
model TestPlan {
  id               String      @id @default(uuid())
  projectId        String      @map("project_id")
  name             String
  description      String?     @db.Text
  githubIssueUrl   String?     @map("github_issue_url")
  githubPrUrl      String?     @map("github_pr_url")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  
  project          Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testCases        TestCase[]
  testRuns         TestRun[]
  
  @@map("test_plans")
}

// Test Case - Individual test scenarios within a plan
model TestCase {
  id                 String          @id @default(uuid())
  planId             String          @map("plan_id")
  title              String
  description        String?         @db.Text
  preconditions      String?         @db.Text
  testSteps          String?         @db.Text
  expectedResults    String?         @db.Text
  acceptanceCriteria String?         @db.Text
  priority           TestPriority    @default(P2) @map("priority")
  status             TestStatus       @default(DRAFT) @map("status")
  executionType      ExecutionType    @default(MANUAL) @map("execution_type")
  githubIssueUrl     String?         @map("github_issue_url")
  githubPrUrl        String?         @map("github_pr_url")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  
  plan               TestPlan        @relation(fields: [planId], references: [id], onDelete: Cascade)
  testResults        TestResult[]
  
  @@map("test_cases")
}

enum ExecutionType {
  MANUAL
  AUTOMATED
}

enum TestPriority {
  P1  // Critical
  P2  // High
  P3  // Medium
  P4  // Low
}

enum TestStatus {
  DRAFT
  ACTIVE
  DEPRECATED
}

// User - Team members who can be assigned test cases
model User {
  id                           String      @id @default(uuid())
  username                     String      @unique
  email                        String      @unique
  passwordHash                 String      @map("password_hash")
  githubUsername               String?     @map("github_username")
  telegramChatId               String?     @map("telegram_chat_id")
  role                         UserRole    @default(TESTER)
  notifyEmailRunComplete       Boolean     @default(true) @map("notify_email_run_complete")
  notifyTelegramOnFailure      Boolean     @default(true) @map("notify_telegram_on_failure")
  notifyDailySummary           Boolean     @default(false) @map("notify_daily_summary")
  createdAt                    DateTime    @default(now()) @map("created_at")
  
  testResults                 TestResult[]
  notifications               Notification[]
  sessions                    Session[]
  
  @@map("users")
}

enum UserRole {
  ADMIN
  TESTER
  VIEWER
}

// Session - For session-based authentication
model Session {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  token        String   @unique
  expiresAt    DateTime @map("expires_at")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("sessions")
}

// Test Run - Group of test case executions
model TestRun {
  id               String      @id @default(uuid())
  planId           String      @map("plan_id")
  name             String
  scheduledAt      DateTime?   @map("scheduled_at")
  startedAt        DateTime?   @map("started_at")
  completedAt      DateTime?   @map("completed_at")
  status           RunStatus   @default(PENDING)
  createdAt        DateTime    @default(now()) @map("created_at")
  
  plan             TestPlan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  testResults      TestResult[]
  
  @@map("test_runs")
}

enum RunStatus {
  PENDING
  RUNNING
  COMPLETED
  CANCELLED
}

// Test Result - Outcome of a test case execution
model TestResult {
  id                     String          @id @default(uuid())
  runId                  String          @map("run_id")
  caseId                 String          @map("case_id")
  assigneeId             String?         @map("assignee_id")
  status                 ResultStatus
  comment                String?         @db.Text
  executedAt             DateTime        @default(now()) @map("executed_at")
  executionDurationMs    Int?            @map("execution_duration_ms")
  githubIssueUrl         String?         @map("github_issue_url")
  createdAt              DateTime        @default(now()) @map("created_at")
  updatedAt              DateTime        @updatedAt @map("updated_at")
  
  run                    TestRun         @relation(fields: [runId], references: [id], onDelete: Cascade)
  testCase               TestCase        @relation(fields: [caseId], references: [id], onDelete: Cascade)
  assignee               User?           @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  
  @@unique([runId, caseId])
  @@map("test_results")
}

enum ResultStatus {
  PASSED
  FAILED
  SKIPPED
  BLOCKED
}

// Notification - Alerts for test events
model Notification {
  id             String          @id @default(uuid())
  userId         String          @map("user_id")
  type           NotificationType
  message        String          @db.Text
  read           Boolean         @default(false)
  telegramSent   Boolean         @default(false) @map("telegram_sent")
  payload        Json?
  createdAt      DateTime        @default(now()) @map("created_at")
  
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("notifications")
}

enum NotificationType {
  RUN_COMPLETED
  CASE_FAILED
  CASE_ASSIGNED
  RUN_SCHEDULED
}

// API Key - For CI/CD webhook authentication
model ApiKey {
  id           String    @id @default(uuid())
  name         String
  keyHash      String    @map("key_hash") @unique
  permissions  String[]  @default([])
  expiresAt    DateTime? @map("expires_at")
  lastUsedAt   DateTime? @map("last_used_at")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  
  @@map("api_keys")
}

// Telegram Settings - Global bot configuration
model TelegramSettings {
  id        String   @id @default(uuid())
  botToken  String   @map("bot_token")
  isActive  Boolean  @default(true) @map("is_active")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  @@map("telegram_settings")
}