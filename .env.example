# Cosmos Solutions — Engineering Platform
# This file documents every environment variable the platform reads.
# Copy to `.env.local` (or set in your deploy target) and fill in real values.
# NEVER commit a real `.env*` file other than this template.

# Application
NEXT_PUBLIC_APP_NAME="Cosmos Solutions"
NODE_ENV="development"

# Database (Postgres)
# Local dev: spin up with `docker run -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres:16`
# Production: use Neon, Supabase, or RDS. Connection string format below.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cosmos_dev"

# Auth (Auth.js / next-auth)
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-32-byte-random-string"

# Observability (deferred — uncomment when wired up)
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""
