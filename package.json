{
  "name": "cosmos-solutions-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Engineering platform for Cosmos Solutions. Monorepo root.",
  "workspaces": [
    "app"
  ],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "npm run dev -w app",
    "build": "npm run build -w app",
    "start": "npm run start -w app",
    "lint": "npm run lint -w app",
    "typecheck": "npm run typecheck -w app",
    "test": "npm run test -w app",
    "test:watch": "npm run test:watch -w app",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
